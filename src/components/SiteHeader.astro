---
import { nav, siteMeta } from '../data/vision';
---

<header
  class="sticky top-0 z-50 border-b border-border-bright/50 bg-surface-raised/90 backdrop-blur-md shadow-[inset_0_-1px_0_0_rgba(196,165,116,0.12)]"
>
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-5 py-4 sm:px-8"
  >
    <a
      href="#welcome"
      class="group flex min-w-0 items-center gap-3"
      aria-label={`${siteMeta.title} — ${siteMeta.tagline}`}
    >
      <span
        class="plate-border relative flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-surface-deep p-0.5 shadow-[0_0_0_1px_rgba(196,165,116,0.25)]"
        aria-hidden="true"
      >
        <img
          src="/prompt-alchemist-logo.jpg"
          alt=""
          width="44"
          height="44"
          class="h-11 w-11 rounded-full object-cover"
          loading="eager"
          decoding="async"
        />
      </span>
      <div class="flex min-w-0 flex-col gap-0.5">
        <span
          class="font-display text-lg font-semibold tracking-tight text-mist transition-colors group-hover:text-ember"
          >{siteMeta.title}</span
        >
        <span class="font-label text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-mist-dim"
          >{siteMeta.tagline}</span
        >
      </div>
    </a>
    <nav aria-label="On this page" class="flex flex-wrap justify-end gap-x-1 gap-y-2 text-sm sm:gap-x-2">
      {
        nav.map(({ href, label }) => (
          <a
            href={href}
            class="rounded-md px-2 py-1 text-ink-muted transition-colors hover:bg-ember/10 hover:text-ember focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ember sm:px-2.5"
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
