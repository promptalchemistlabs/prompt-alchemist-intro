---
import { siteNav, siteMeta } from '../data/vision';
---

<footer class="relative border-t border-border-bright/40 bg-surface-deep/80 px-5 py-12 sm:px-8">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-ember/35 to-transparent"
    aria-hidden="true"
  />
  <div class="mx-auto flex max-w-5xl flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-display text-xl font-semibold text-mist">{siteMeta.title}</p>
      <p class="mt-2 max-w-md font-display text-sm italic text-mist-dim">{siteMeta.tagline}</p>
      <p class="mt-3 text-sm text-ink-muted">{siteMeta.versionNote}</p>
      <p class="mt-4 font-mono text-[0.65rem] tracking-wider text-ink-muted/70" aria-hidden="true">
        H₂O · Pb · NH₃ — clarity compounds
      </p>
    </div>
    <nav aria-label="Footer navigation" class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-ink-muted">
      {siteNav.map(({ href, label }) => (
        <a href={href} class="transition-colors hover:text-ember">
          {label}
        </a>
      ))}
    </nav>
  </div>
</footer>
