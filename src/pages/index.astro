---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharterHighlightIcon from '../components/CharterHighlightIcon.astro';
import PillarIcon from '../components/PillarIcon.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { richText } from '../lib/rich';
import AudienceIcon from '../components/AudienceIcon.astro';
import {
  audienceGroups,
  charterHighlights,
  communityRules,
  gap,
  memberAccess,
  nav,
  northStar,
  pillars,
  siteMeta,
  welcome,
} from '../data/vision';
---

<BaseLayout>
  <SiteHeader />
  <main>
    <section
      id="welcome"
      class="relative overflow-hidden border-b border-border schematic-bg px-5 py-16 sm:px-8 sm:py-24"
    >
      <div
        class="pointer-events-none absolute -right-20 top-0 h-80 w-80 rounded-full bg-ember/12 blur-3xl"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute -left-16 bottom-0 h-64 w-64 rounded-full bg-mist/5 blur-3xl"
        aria-hidden="true"
      />
      <div class="relative mx-auto flex max-w-5xl flex-col items-center gap-12 lg:flex-row lg:items-start lg:gap-16">
        <div class="hero-logo-cluster relative mx-auto shrink-0 lg:mx-0 lg:pt-2">
          <div class="hero-logo-outer-ring" aria-hidden="true" />
          <div class="hero-logo-glow-ring" aria-hidden="true" />
          <div class="hero-logo-glow-ring hero-logo-glow-ring--slow" aria-hidden="true" />
          <div class="hero-logo-glow-pulse" aria-hidden="true" />
          <div class="hero-logo-sparkles" aria-hidden="true">
            <span class="spark spark-1" />
            <span class="spark spark-2" />
            <span class="spark spark-3" />
            <span class="spark spark-4" />
            <span class="spark spark-5" />
            <span class="spark spark-6" />
          </div>
          <span
            class="hero-logo-frame plate-border relative z-[1] block rounded-full bg-surface-deep p-1.5"
            aria-hidden="true"
          >
            <img
              src="/prompt-alchemist-logo.jpg"
              alt=""
              width="176"
              height="176"
              class="relative z-[1] h-40 w-40 rounded-full object-cover sm:h-44 sm:w-44"
              loading="eager"
              decoding="async"
            />
          </span>
        </div>
        <div class="max-w-2xl flex-1 text-center lg:text-left">
          <p class="font-label mb-3 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-ember">
            Welcome
          </p>
          <h1 class="hero-title font-display text-4xl font-semibold leading-tight sm:text-5xl lg:text-[2.75rem] lg:leading-[1.12]">
            {siteMeta.title}
          </h1>
          <p class="mt-4 font-display text-xl italic text-ember sm:text-2xl">{siteMeta.tagline}</p>
          <p
            class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-mist/92 lg:mx-0"
            set:html={richText(welcome.lead)}
          />
        </div>
      </div>
    </section>

    <section
      id="charter-glance"
      class="relative border-b border-border bg-surface-raised/35 schematic-bg px-5 py-16 sm:px-8"
    >
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-ember/[0.04] via-transparent to-transparent" aria-hidden="true" />
      <div class="relative mx-auto max-w-5xl">
        <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">
          Charter at a glance
        </h2>
        <p class="mt-5 max-w-2xl text-ink-muted">
          Four commitments that show up in how we curate, teach, and run the room — before you read the full
          charter below.
        </p>
        <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {
            charterHighlights.map((item) => (
              <li class="plate-card flex flex-col overflow-hidden p-0">
                <div class="flex flex-1 flex-col p-5 pt-5">
                  <CharterHighlightIcon name={item.icon} class="mb-4" />
                  <span class="font-label text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-ember">
                    {item.title}
                  </span>
                  <p class="mt-3 text-sm leading-relaxed text-mist/88">{item.detail}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section id="pillars" class="border-b border-border px-5 py-16 sm:px-8">
      <div class="mx-auto max-w-5xl">
        <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">What we do</h2>
        <p class="mt-5 max-w-2xl text-ink-muted">
          Three pillars — how we learn, build skill, and shape culture together.
        </p>
        <ul class="mt-12 grid gap-8 md:grid-cols-3">
          {
            pillars.map((p, i) => (
              <li
                class:list={[
                  'plate-card flex flex-col overflow-hidden p-0',
                  i === 1 &&
                    'md:-translate-y-2 md:shadow-[0_0_0_1px_rgba(196,165,116,0.28),0_20px_50px_-24px_rgba(0,0,0,0.55)]',
                ]}
              >
                <div class="flex flex-1 flex-col p-6">
                  <PillarIcon name={p.id} class="mb-4" />
                  <span class="font-label text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-ember">
                    {p.title}
                  </span>
                  <h3 class="mt-2 font-display text-xl font-semibold text-mist">{p.subtitle}</h3>
                  <p class="mt-4 flex-1 text-sm leading-relaxed text-mist/85" set:html={richText(p.body)} />
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section id="north-star" class="relative border-b border-border bg-surface-raised/25 schematic-bg px-5 py-16 sm:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:gap-16">
          <!-- left: text -->
          <div class="flex-1">
            <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">Ultimate vision</h2>
            <p class="mt-5 text-ink-muted">Our north star for humans, AI, and robotics in the loop.</p>
            <blockquote
              class="plate-card mt-10 border-l-4 border-l-ember py-5 pl-6 pr-5 font-display text-xl italic leading-relaxed text-mist sm:text-2xl"
            >
              {northStar.quote}
            </blockquote>
            <p class="mt-8 text-base leading-relaxed text-mist/85" set:html={richText(northStar.context)} />
          </div>
          <!-- right: image -->
          <div class="w-full shrink-0 lg:w-[46%]">
            <div class="plate-border overflow-hidden rounded-2xl shadow-[0_8px_40px_-12px_rgba(0,0,0,0.65)]">
              <img
                src="/img/kampung-alchemist.png"
                alt="A kampung community where humans, AI robots and nature coexist"
                width="800"
                height="800"
                class="w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="audience" class="border-b border-border px-5 py-16 sm:px-8">
      <div class="mx-auto max-w-5xl">
        <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">Who this is for</h2>
        <p class="mt-5 max-w-2xl text-ink-muted">Three situations — one shared gap: turning AI access into reliable, repeatable results.</p>
        <ul class="mt-10 grid list-none gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            audienceGroups.map((group) => (
              <li class="plate-card flex flex-col overflow-hidden p-0">
                <div class="flex flex-1 flex-col p-6">
                  <AudienceIcon name={group.icon} class="mb-4" />
                  <h3 class="font-display text-xl font-semibold text-mist">{group.label}</h3>
                  <ul class="mt-3 flex flex-wrap gap-1.5 list-none p-0">
                    {group.roles.map((role) => (
                      <li class="rounded-full border border-ember/30 bg-ember/[0.07] px-2.5 py-0.5 font-label text-[0.6rem] font-semibold uppercase tracking-[0.14em] text-ember/80">
                        {role}
                      </li>
                    ))}
                  </ul>
                  <p class="mt-4 flex-1 text-sm leading-relaxed text-mist/88" set:html={richText(group.body)} />
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section id="gap" class="relative border-b border-border bg-surface-raised/25 schematic-bg px-5 py-16 sm:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16">
          <!-- left: illustration -->
          <div class="w-full shrink-0 lg:w-[44%]">
            <div class="plate-border overflow-hidden rounded-2xl shadow-[0_8px_40px_-12px_rgba(0,0,0,0.65)]">
              <img
                src="/img/gap-illustration.png"
                alt="Illustration contrasting scattered, inconsistent AI usage on the left with a structured, clear workflow on the right"
                width="800"
                height="530"
                class="w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <!-- right: text -->
          <div class="flex-1">
            <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">
              The gap we address
            </h2>
            <div class="plate-card mt-8 p-6 sm:p-8">
              <p class="text-lg leading-relaxed text-mist/90" set:html={richText(gap.body)} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="community" class="border-b border-border px-5 py-16 sm:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">
          Community rules &amp; norms
        </h2>
        <ol
          class="plate-card mt-10 list-decimal space-y-5 py-6 pl-9 pr-6 text-base leading-relaxed text-mist/90 marker:font-label marker:text-[0.7rem] marker:font-semibold marker:text-ember sm:pl-10 sm:pr-8"
        >
          {communityRules.map((rule) => <li set:html={richText(rule)} />)}
        </ol>
        <p class="mt-8 text-sm text-ink-muted">{memberAccess.footnote}</p>
      </div>
    </section>

    <section id="access" class="schematic-bg px-5 py-16 sm:px-8">
      <div class="mx-auto max-w-3xl plate-card p-8 sm:p-10">
        <h2 class="section-ornament font-display text-3xl font-semibold text-mist sm:text-4xl">Member access</h2>
        <p class="mt-8 text-base leading-relaxed text-mist/90" set:html={richText(memberAccess.body)} />
      </div>
    </section>
  </main>

  <footer class="relative border-t border-border-bright/40 bg-surface-deep/80 px-5 py-12 sm:px-8">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-ember/35 to-transparent"
      aria-hidden="true"
    />
    <div class="mx-auto flex max-w-5xl flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-display text-xl font-semibold text-mist">{siteMeta.title}</p>
        <p class="mt-2 max-w-md font-display text-sm italic text-mist-dim">{siteMeta.tagline}</p>
        <p class="mt-3 text-sm text-ink-muted">{siteMeta.versionNote}</p>
        <p class="mt-4 font-mono text-[0.65rem] tracking-wider text-ink-muted/70" aria-hidden="true">
          H₂O · Pb · NH₃ — clarity compounds
        </p>
      </div>
      <nav aria-label="Footer" class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-ink-muted">
        {nav.map(({ href, label }) => (
          <a href={href} class="transition-colors hover:text-ember">
            {label}
          </a>
        ))}
      </nav>
    </div>
  </footer>
</BaseLayout>
